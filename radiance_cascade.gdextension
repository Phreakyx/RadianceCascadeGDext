[configuration]

entry_symbol = "radiance_cascade_library_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]

windows.debug.x86_64   = "res://addons/radiance_cascade/bin/radiance_cascade.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/radiance_cascade/bin/radiance_cascade.windows.template_release.x86_64.dll"
linux.debug.x86_64     = "res://addons/radiance_cascade/bin/libradiance_cascade.linux.template_debug.x86_64.so"
linux.release.x86_64   = "res://addons/radiance_cascade/bin/libradiance_cascade.linux.template_release.x86_64.so"
macos.debug            = "res://addons/radiance_cascade/bin/radiance_cascade.macos.template_debug.framework"
macos.release          = "res://addons/radiance_cascade/bin/radiance_cascade.macos.template_release.framework"
